# Required
PRIVATE_KEY=
RPC_URL=https://api.mainnet-beta.solana.com

# Optional (with defaults)
DRY_RUN=true
MIN_PROFIT_USD=0.05
MAX_TRADE_SOL=0.1
SLIPPAGE_BPS=50
CHECK_INTERVAL_MS=3000
DEBUG_MODE=false
MAX_QUOTE_AGE_MS=1500
MAX_REQUESTS_PER_MIN=60
PERSISTENCE_REQUIRED=2
SCAN_MAX_PAIRS=50
SCAN_MIN_LIQUIDITY_USD=500000
SCAN_PROFIT_MULTIPLIER=2
SCAN_ENABLE_TRIANGULAR=true
SCAN_QUOTE_SIZE_SOL=0.05
QUOTE_SIZES=0.05,0.1
